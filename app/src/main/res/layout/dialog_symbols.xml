<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- CARD 1: Filters (Font & Subset) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/grad_start"
                        android:layout_marginLeft="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ترتیباتِ علامت (Symbol Settings)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Font Selection Selector -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="فونٹ (Font):"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1F5F9"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CBD5E1"
                    android:layout_marginBottom="14dp">

                    <Spinner
                        android:id="@+id/fontSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingHorizontal="8dp"
                        android:background="@null" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Subset Selection Selector -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ذیلی سیٹ (Subset):"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1F5F9"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CBD5E1">

                    <Spinner
                        android:id="@+id/subsetSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:paddingHorizontal="8dp"
                        android:background="@null" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 2: Symbol Grid -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <GridView
                    android:id="@+id/symbolsGrid"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:numColumns="6"
                    android:verticalSpacing="8dp"
                    android:horizontalSpacing="8dp"
                    android:stretchMode="columnWidth"
                    android:gravity="center"
                    android:nestedScrollingEnabled="true"
                    android:scrollbars="vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 3: Recent Symbols -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="16dp"
                        android:background="@color/grad_start"
                        android:layout_marginLeft="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حالیہ استعمال شدہ سمبلز"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <GridView
                    android:id="@+id/recentSymbolsGrid"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:numColumns="6"
                    android:verticalSpacing="8dp"
                    android:horizontalSpacing="8dp"
                    android:stretchMode="columnWidth"
                    android:gravity="center"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>